{
  "title": "Helper Human-Level Parity",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["helper", "parity", "slo"],
  "panels": [
    {
      "title": "Conversation Success Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "helper_conversation_success_rate", "legendFormat": "success_rate" }
      ]
    },
    {
      "title": "Helpfulness Average",
      "type": "timeseries",
      "targets": [
        { "expr": "helper_user_helpfulness_average", "legendFormat": "helpfulness" }
      ]
    },
    {
      "title": "Citation Coverage",
      "type": "timeseries",
      "targets": [
        { "expr": "helper_citation_coverage", "legendFormat": "citation_coverage" }
      ]
    },
    {
      "title": "TTFT Breakdown",
      "type": "timeseries",
      "targets": [
        { "expr": "helper_model_ttft_ms", "legendFormat": "model_ttft_ms" },
        { "expr": "helper_transport_ttft_ms", "legendFormat": "transport_ttft_ms" },
        { "expr": "helper_end_to_end_ttft_ms", "legendFormat": "end_to_end_ttft_ms" }
      ]
    },
    {
      "title": "Tool Success Ratio",
      "type": "timeseries",
      "targets": [
        { "expr": "helper_tool_success_ratio", "legendFormat": "tool_success_ratio" }
      ]
    }
  ]
}
