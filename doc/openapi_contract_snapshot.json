{
  "openapi": "3.0.1",
  "info": {
    "title": "Helper API",
    "version": "v1",
    "description": "Contract snapshot for Helper backend."
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "security": [
    {
      "ApiKey": []
    },
    {
      "Bearer": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      },
      "Bearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health status"
      }
    },
    "/api/handshake": {
      "get": {
        "summary": "Auth handshake"
      }
    },
    "/api/control-plane": {
      "get": {
        "summary": "Backend control-plane snapshot"
      }
    },
    "/api/capabilities/catalog": {
      "get": {
        "summary": "Capability catalog snapshot for models, templates, tools, and extensions"
      }
    },
    "/api/runtime/logs": {
      "get": {
        "summary": "Tail real runtime log sources for machine log review"
      }
    },
    "/api/auth/session": {
      "post": {
        "summary": "Issue short-lived session token"
      }
    },
    "/api/auth/keys": {
      "get": {
        "summary": "List machine keys metadata"
      }
    },
    "/api/auth/keys/rotate": {
      "post": {
        "summary": "Rotate or issue machine key"
      }
    },
    "/api/auth/keys/{keyId}/revoke": {
      "post": {
        "summary": "Revoke machine key by key id"
      }
    },
    "/api/metrics": {
      "get": {
        "summary": "Runtime metrics snapshot"
      }
    },
    "/api/metrics/web-research": {
      "get": {
        "summary": "Web-research telemetry snapshot"
      }
    },
    "/api/metrics/human-like-conversation": {
      "get": {
        "summary": "Human-like conversation quality dashboard snapshot"
      }
    },
    "/api/metrics/tool-audit-consistency": {
      "get": {
        "summary": "Compare conversation tool-call counters vs tool audit stream"
      }
    },
    "/api/metrics/prometheus": {
      "get": {
        "summary": "Prometheus text metrics export"
      }
    },
    "/api/metrics/parity-certification": {
      "post": {
        "summary": "Generate parity certification snapshot report"
      }
    },
    "/api/metrics/parity-gate": {
      "post": {
        "summary": "Evaluate parity KPI gate against thresholds"
      }
    },
    "/api/metrics/parity-window-gate": {
      "post": {
        "summary": "Evaluate rolling parity KPI window gate"
      }
    },
    "/api/metrics/parity-benchmark": {
      "post": {
        "summary": "Run generation\u002Bdiagnostics parity benchmark corpora"
      }
    },
    "/api/metrics/closed-loop-predictability": {
      "post": {
        "summary": "Run closed-loop predictability protocol for top incident classes"
      }
    },
    "/api/openapi.json": {
      "get": {
        "summary": "OpenAPI contract document"
      }
    },
    "/api/settings/provider-profiles": {
      "get": {
        "summary": "List provider profiles and activation state"
      }
    },
    "/api/settings/provider-profiles/active": {
      "get": {
        "summary": "Get active provider profile"
      }
    },
    "/api/settings/provider-profiles/activate": {
      "post": {
        "summary": "Activate provider profile"
      }
    },
    "/api/settings/provider-profiles/recommend": {
      "post": {
        "summary": "Recommend provider profile for workload"
      }
    },
    "/api/settings/runtime-doctor/run": {
      "post": {
        "summary": "Run runtime provider diagnostics"
      }
    },
    "/api/chat": {
      "post": {
        "summary": "Run chat turn",
        "operationId": "chatCompleteTurn"
      }
    },
    "/api/chat/stream": {
      "post": {
        "summary": "Run streaming chat turn",
        "operationId": "chatStreamTurn"
      }
    },
    "/api/chat/{conversationId}": {
      "get": {
        "summary": "Get conversation"
      },
      "delete": {
        "summary": "Delete conversation"
      }
    },
    "/api/chat/{conversationId}/resume": {
      "post": {
        "summary": "Resume unfinished chat turn"
      }
    },
    "/api/chat/{conversationId}/stream/resume": {
      "post": {
        "summary": "Resume interrupted streaming turn from cursor offset"
      }
    },
    "/api/chat/{conversationId}/turns/{turnId}/regenerate": {
      "post": {
        "summary": "Regenerate assistant response for specific turn"
      }
    },
    "/api/chat/{conversationId}/preferences": {
      "post": {
        "summary": "Update conversation memory preferences"
      }
    },
    "/api/chat/{conversationId}/background/{taskId}/cancel": {
      "post": {
        "summary": "Cancel queued background follow-through task"
      }
    },
    "/api/chat/{conversationId}/topics/{topicId}": {
      "post": {
        "summary": "Enable or disable proactive topic subscription"
      }
    },
    "/api/chat/{conversationId}/memory": {
      "get": {
        "summary": "List active conversation memory items and memory policy"
      }
    },
    "/api/chat/{conversationId}/memory/{memoryId}": {
      "delete": {
        "summary": "Delete memory item from conversation memory"
      }
    },
    "/api/chat/{conversationId}/branches": {
      "post": {
        "summary": "Create branch from turn"
      }
    },
    "/api/chat/{conversationId}/branches/{branchId}/activate": {
      "post": {
        "summary": "Activate existing branch"
      }
    },
    "/api/chat/{conversationId}/branches/compare": {
      "get": {
        "summary": "Compare branch divergence and provenance"
      }
    },
    "/api/chat/{conversationId}/branches/merge": {
      "post": {
        "summary": "Merge one branch into another branch"
      }
    },
    "/api/chat/{conversationId}/repair": {
      "post": {
        "summary": "Repair conversation after misunderstanding"
      }
    },
    "/api/chat/{conversationId}/feedback": {
      "post": {
        "summary": "Submit user helpfulness feedback"
      }
    },
    "/api/helper/generate": {
      "post": {
        "summary": "Generate project"
      }
    },
    "/api/templates": {
      "get": {
        "summary": "List available templates"
      }
    },
    "/api/templates/promotion-profile": {
      "get": {
        "summary": "Resolved template promotion feature profile"
      }
    },
    "/api/templates/{templateId}/versions": {
      "get": {
        "summary": "List template versions and active status"
      }
    },
    "/api/templates/{templateId}/activate/{version}": {
      "post": {
        "summary": "Activate specific template version"
      }
    },
    "/api/templates/{templateId}/rollback": {
      "post": {
        "summary": "Rollback template to previous active version"
      }
    },
    "/api/templates/{templateId}/certify/{version}": {
      "post": {
        "summary": "Certify template version against compile/artifact/smoke gates"
      }
    },
    "/api/templates/certification-gate": {
      "post": {
        "summary": "Run certification gate for active template versions"
      }
    },
    "/api/helper/research": {
      "post": {
        "summary": "Research mode"
      }
    },
    "/api/rag/search": {
      "post": {
        "summary": "Vector search"
      }
    },
    "/api/rag/ingest": {
      "post": {
        "summary": "Ingest content into vector store"
      }
    },
    "/api/goals": {
      "get": {
        "summary": "List goals"
      },
      "post": {
        "summary": "Add goal"
      }
    },
    "/api/build": {
      "post": {
        "summary": "Build project"
      }
    },
    "/api/fs/write": {
      "post": {
        "summary": "Write file via guarded API"
      }
    },
    "/api/evolution/status": {
      "get": {
        "summary": "Evolution status"
      }
    },
    "/api/evolution/library": {
      "get": {
        "summary": "Library queue snapshot"
      }
    },
    "/api/evolution/start": {
      "post": {
        "summary": "Start evolution"
      }
    },
    "/api/evolution/pause": {
      "post": {
        "summary": "Pause evolution"
      }
    },
    "/api/evolution/stop": {
      "post": {
        "summary": "Stop evolution"
      }
    },
    "/api/evolution/reset": {
      "post": {
        "summary": "Reset evolution queue"
      }
    },
    "/api/indexing/start": {
      "post": {
        "summary": "Start indexing"
      }
    },
    "/api/indexing/pause": {
      "post": {
        "summary": "Pause indexing"
      }
