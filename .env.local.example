# Local development configuration template
# Generated from src/Helper.Api/Backend/Configuration/BackendEnvironmentInventory.cs
# Copy secrets from your secret manager; do not commit real values.

# Runtime Paths And Bootstrap
# Primary backend bootstrap key.
HELPER_API_KEY=<set-me>

# Optional explicit helper root. Usually auto-discovered.
# Keep unset unless auto-discovery is wrong.
# HELPER_ROOT=C:\HELPER

# Runtime data root. Must live outside the repository source tree.
HELPER_DATA_ROOT=<path-outside-repo>

# Workspace/project output root. Defaults under HELPER_DATA_ROOT.
HELPER_PROJECTS_ROOT=<path-outside-repo>\PROJECTS

# Library root. Defaults under HELPER_DATA_ROOT.
HELPER_LIBRARY_ROOT=<path-outside-repo>\library

# Logs root. Defaults under HELPER_DATA_ROOT.
HELPER_LOGS_ROOT=<path-outside-repo>\LOG

# Template library root. Defaults under HELPER_LIBRARY_ROOT\forge_templates.
HELPER_TEMPLATES_ROOT=<path-outside-repo>\library\forge_templates

# Auth And Bootstrap
# Dedicated session signing secret for issued browser tokens.
HELPER_SESSION_SIGNING_KEY=<set-a-long-random-secret>

# Allow local `/api/auth/session` bootstrap outside the default Development/Local inference.
# Leave unset for normal local development.
# HELPER_AUTH_ALLOW_LOCAL_BOOTSTRAP=true

# Model Warmup
# Warmup intensity at startup.
HELPER_MODEL_WARMUP_MODE=minimal

# Enable model preflight probes during startup.
# HELPER_MODEL_PREFLIGHT_ENABLED=false

# Frontend Local
# Frontend API protocol when VITE_HELPER_API_BASE is not set.
VITE_HELPER_API_PROTOCOL=http

# Frontend API host when VITE_HELPER_API_BASE is not set.
VITE_HELPER_API_HOST=localhost

# Frontend API port when VITE_HELPER_API_BASE is not set.
VITE_HELPER_API_PORT=5056

# Explicit frontend API base URL.
VITE_HELPER_API_BASE=http://localhost:5056

# Optional conversation surface scope override.
# VITE_HELPER_SESSION_SCOPES_CONVERSATION=chat:read,chat:write,feedback:write

# Optional runtime-console surface scope override.
# VITE_HELPER_SESSION_SCOPES_RUNTIME_CONSOLE=metrics:read

# Optional builder surface scope override.
# VITE_HELPER_SESSION_SCOPES_BUILDER=chat:read,chat:write,tools:execute,build:run,fs:write

# Optional evolution surface scope override.
# VITE_HELPER_SESSION_SCOPES_EVOLUTION=evolution:control,metrics:read

