{
  "openapi": "3.0.1",
  "info": {
    "title": "Helper Runtime Review Slice API",
    "version": "v1",
    "description": "Public-safe read-only runtime review API for HELPER."
  },
  "servers": [
    {
      "url": "http://localhost:5076"
    }
  ],
  "paths": {
    "/api/about": {
      "get": {
        "summary": "Runtime slice metadata"
      }
    },
    "/api/health": {
      "get": {
        "summary": "Health status"
      }
    },
    "/api/readiness": {
      "get": {
        "summary": "Readiness snapshot"
      }
    },
    "/api/openapi.json": {
      "get": {
        "summary": "OpenAPI contract document"
      }
    },
    "/api/runtime/logs": {
      "get": {
        "summary": "Sanitized runtime log review snapshot"
      }
    },
    "/api/evolution/status": {
      "get": {
        "summary": "Evolution status snapshot"
      }
    },
    "/api/evolution/library": {
      "get": {
        "summary": "Library indexing queue snapshot"
      }
    },
    "/api/telemetry/routes": {
      "get": {
        "summary": "Route telemetry snapshot"
      }
    }
  }
}
